# =============================================================================
# TƼTBIQ (APPLICATION) KONFIQURASIYASI
# =============================================================================
# Bu fayl layihənin işləməsi üçün lazım olan bütün mühit dəyişənlərinin
# nümunəsini əks etdirir. Lokal inkişaf üçün bu faylı köçürüb ".env.local"
# adı ilə saxlayın və dəyərləri öz mühitinizə uyğun doldurun.
#
#   cp .env.example .env.local
#
# QAYDA: "NEXT_PUBLIC_" prefiksi olan dəyişənlər brauzerdə (client) əlçatan
# olur. Məxfi dəyərləri (parol, token, açar və s.) HEÇ VAXT bu prefiks ilə
# elan ETMƏYİN.
# =============================================================================

# -----------------------------------------------------------------------------
# TƼTBIQ ƏSAS PARAMETRLƼRI
# -----------------------------------------------------------------------------
# İşlək mühit: development | test | production
NODE_ENV=development

# Tətbiqin işlədiyi əsas URL (server tərəfli linklər, redirectlər üçün)
APP_BASE_URL=http://localhost:3000

# Tətbiqin rəsmi adı (naviqasiya başlığı, meta teqlər üçün)
NEXT_PUBLIC_APP_NAME="Dövlət Əmlakının Özəlləşdirilməsinin Təşkili Şöbəsi"

# Tətbiqin qısaldılmış adı (mobil görünüş, footer və s.)
NEXT_PUBLIC_APP_SHORT_NAME="Əmlak İdarəetmə Sistemi"

# -----------------------------------------------------------------------------
# DATA MƼNBƼYİ REJİMİ
# -----------------------------------------------------------------------------
# Servislərin hansı data mənbəyindən istifadə edəcəyini müəyyən edir.
# Yalnız iki dəyər dəstəklənir:
#   mock -> Statik mock datadan istifadə olunur (backend tələb olunmur)
#   api  -> Real backend API-yə qoşulur
APP_DATA=mock

# -----------------------------------------------------------------------------
# API / BACKEND İNTEQRASİYASI
# -----------------------------------------------------------------------------
# Backend API-nin bazə URL-i (server komponentləri üçün, gizli saxlanıla bilər)
API_BASE_URL=https://api.example.gov.az

# Backend API-nin brauzerdən çağırılan public bazə URL-i (lazım olduqda)
NEXT_PUBLIC_API_BASE_URL=https://api.example.gov.az

# API sorğuları üçün timeout (millisaniyə)
API_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# AUTENTİFİKASİYA / TƼHLÜKƼSİZLİK
# -----------------------------------------------------------------------------
# Sessiya/JWT üçün məxfi açar (production-da güclü, təsadüfi dəyər istifadə edin)
AUTH_SECRET=change-this-secret-in-production

# Sessiyanın etibarlılıq müddəti (saniyə). Default: 8 saat
AUTH_SESSION_MAX_AGE=28800

# Autentifikasiya cookie adı
AUTH_COOKIE_NAME=aptr_session

# -----------------------------------------------------------------------------
# TƼHLÜKƼSİZLİK VƼ MƼHDUDİYYƼTLƼR
# -----------------------------------------------------------------------------
# Giriş cəhdlərinin maksimum sayı (rate-limit üçün)
LOGIN_MAX_ATTEMPTS=5

# Bloklanma müddəti (dəqiqə)
LOGIN_LOCKOUT_MINUTES=15

# -----------------------------------------------------------------------------
# LOKALİZASİYA
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_LOCALE=az
NEXT_PUBLIC_SUPPORTED_LOCALES=az,en,ru

# -----------------------------------------------------------------------------
# MONİTORİNQ / LOGLAMA (opsional, gələcək inteqrasiyalar üçün)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_ANALYTICS=false
LOG_LEVEL=info
